# Huginn environment variables (example placeholders only — no real secrets).
# Copy to .env and fill in, or set these in the norse-stack compose file.

# --- Control-plane security ---------------------------------------------------
# Bearer token gating mutating HTTP endpoints (/api/breaker/*, /api/fills/mock,
# PUT /api/strategy/config). FAILS CLOSED: when unset, those endpoints return
# 503 and refuse the mutation. Set a strong random value to enable them.
HUGINN_API_TOKEN=changeme-generate-a-strong-random-token

# Allowed CORS origin for the operator dashboard. Echoed in
# Access-Control-Allow-Origin; never set to "*". Defaults to the value below.
HUGINN_DASHBOARD_ORIGIN=http://localhost:8084

# --- Core wiring (see README for the full table) ------------------------------
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPICS=features.obi.v1
# KAFKA_GROUP_ID=huginn
# STRATEGY_NAME=obi
# SERVER_PORT=8081
# DATABASE_ENABLED=true
# DATABASE_URL=postgres://user:password@localhost:5432/huginn
